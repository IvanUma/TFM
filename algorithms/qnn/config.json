{
    "approach": "clifford",
    "random_seed": 42,
    "qnn": {
        "dataset": "iris",
        "datasets_to_run": [
            "iris",
            "wine",
            "breast_cancer"
        ],
        "test_split": 0.2
    },
    "population": {
        "mu": 80,
        "lambda": 50
    },
    "variation": {
        "crossover_prob": 0.75,
        "mutation_prob": 0.25,
        "mutation_indpb": 0.25
    },
    "evolution": {
        "generations": 150,
        "guided_individual_length_min": 10,
        "guided_individual_length_factor": 2,
        "patience": 35,
        "patience_window": 10,
        "improvement_epsilon": 0.005
    },
    "evaluation": {
        "shots_start": 1024,
        "shots_end": 4096,
        "final_validation_shots": 8192,
        "cobyla_maxiter_factor": 10
    },
    "encoding": {
        "enable_input_params": true,
        "param_block_prob": 0.35,
        "manual_input_values": [
            0.5,
            1.0,
            1.5,
            2.0,
            2.5,
            3.0
        ]
    },
    "approaches": [
        "clifford",
        "rotation"
    ],
    "execution": {
        "multiprocessing": false,
        "processes": null,
        "device": "auto",
        "statevector_max_parallel_threads": 1
    }
}