{
    "approach": "rotation",
    "random_seed": 42,
    "qnn": {
        "dataset": "breast_cancer",
        "test_split": 0.2,
        "val_split": 0.35
    },
    "population": {
        "mu": 60,
        "lambda": 80
    },
    "variation": {
        "crossover_prob": 0.5,
        "mutation_prob": 0.5,
        "mutation_indpb": 0.2,
        "crossover_indpb": 0.5
    },
    "evolution": {
        "generations": 150,
        "guided_individual_length_min": 10,
        "guided_individual_length_factor": 6,
        "patience": 30,
        "patience_window": 10,
        "improvement_epsilon": 0.0005,
        "champion_inheritance_prob": 0.6,
        "champion_check_k": 4,
        "max_champion_resets": 2
    },
    "evaluation": {
        "cobyla_maxiter_factor": 18
    },
    "encoding": {
        "enable_input_params": true,
        "param_block_prob": 0.2,
        "manual_input_values": [
            0.5,
            1.0,
            1.5,
            2.0,
            2.5,
            3.0
        ]
    },
    "approaches": [
        "clifford",
        "rotation"
    ],
    "execution": {
        "multiprocessing": true,
        "processes": null,
        "device": "auto",
        "statevector_max_parallel_threads": 1
    }
}
